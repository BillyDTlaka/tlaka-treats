generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AmbassadorStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum KycStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  BAKING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PricingTier {
  RETAIL
  AMBASSADOR
  WHOLESALE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ProductClassification {
  SELLABLE     // Finished item we produce and sell to customers
  INGREDIENT   // Raw material used in production
  PACKAGING    // Packaging used for products
  CONSUMABLE   // Other consumables used internally
  SERVICE      // Fees, delivery, or other services
}

enum UomType {
  WEIGHT   // kg, g, mg, lb, oz
  VOLUME   // l, ml, fl oz
  COUNT    // units, pcs, boxes, bags, packs
  LENGTH   // m, cm, mm
  OTHER
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles      UserRole[]
  ambassador Ambassador?
  orders     Order[]
  addresses  Address[]
  quotesAsCustomer Quote[] @relation("QuoteCustomer")
  quotesCreated    Quote[] @relation("QuoteCreatedBy")
  employee   Employee?
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       UserRole[]
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Permission {
  id      String @id @default(cuid())
  action  String // create | read | update | delete | manage
  subject String // order | product | commission | user | payout | ambassador

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([action, subject, roleId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String? // Home, Work, etc.
  street     String
  suburb     String?
  city       String
  province   String
  postalCode String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── Ambassador ───────────────────────────────────────────────────────────────

model Ambassador {
  id             String           @id @default(cuid())
  userId         String           @unique
  code           String           @unique // shareable referral code e.g. TT-BILLY01
  commissionRate Decimal          @default(0.10) @db.Decimal(5, 4)
  status         AmbassadorStatus @default(PENDING)
  bio            String?

  // KYC fields
  kycStatus      KycStatus        @default(NOT_SUBMITTED)
  kycData        Json?            // { phone, address:{street,suburb,city,province,postalCode}, idType, idNumber, idDocumentUrl, submittedAt }
  kycNote        String?          // Admin review note (reason for rejection, etc.)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  commissions Commission[]
  payouts     Payout[]
  quotes      Quote[]
}

// ─── Products ─────────────────────────────────────────────────────────────────

model UnitOfMeasure {
  id           String   @id @default(cuid())
  name         String   @unique  // e.g. "Kilogram"
  abbreviation String   @unique  // e.g. "kg"
  type         UomType  @default(OTHER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products          Product[]
  stockItems        StockItem[]
  recipeIngredients RecipeIngredient[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id             String                @id @default(cuid())
  name           String
  description    String?
  brand          String?               // Brand name (e.g. Tlaka Treats, or a third-party brand)
  supplierId     String?               // FK to Supplier — who we buy/source this product from
  imageUrl       String?               // Primary image URL (for customer-facing display)
  images         Json?                 // Array of {url:string, isPrimary:boolean} for gallery
  classification ProductClassification @default(SELLABLE)
  isActive       Boolean               @default(true)
  categoryId     String?
  uomId          String?               // FK → UnitOfMeasure
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  category        Category?      @relation(fields: [categoryId], references: [id])
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  uom             UnitOfMeasure? @relation(fields: [uomId], references: [id])
  variants        ProductVariant[]
  stockItem       StockItem?
  recipesAsOutput Recipe[]       @relation("RecipeOutput")
}

model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  name        String // e.g. "12 Pack", "24 Pack"
  description String?
  isActive    Boolean @default(true)

  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices     VariantPrice[]
  orderItems OrderItem[]
  quoteItems QuoteItem[]
}

model VariantPrice {
  id        String      @id @default(cuid())
  variantId String
  tier      PricingTier
  price     Decimal     @db.Decimal(10, 2)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, tier])
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  customerId   String
  ambassadorId String? // null = direct order, no commission
  addressId    String?
  status       OrderStatus @default(PENDING)
  subtotal     Decimal     @db.Decimal(10, 2)
  deliveryFee  Decimal     @default(0) @db.Decimal(10, 2)
  total        Decimal     @db.Decimal(10, 2)
  notes          String?
  paymentRef     String?
  paidAt         DateTime?
  quoteId        String?
  discountType   String?
  discountValue  Decimal?  @db.Decimal(10, 2)
  discountAmount Decimal   @default(0) @db.Decimal(10, 2)
  invoiceNumber  String?   @unique
  invoicedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer   User        @relation(fields: [customerId], references: [id])
  ambassador Ambassador? @relation(fields: [ambassadorId], references: [id])
  address    Address?    @relation(fields: [addressId], references: [id])
  items      OrderItem[]
  commission Commission?
  statusLogs OrderStatusLog[]
  financeTransaction FinanceTransaction?
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── Commissions & Payouts ────────────────────────────────────────────────────

model Commission {
  id           String           @id @default(cuid())
  orderId      String           @unique
  ambassadorId String
  amount       Decimal          @db.Decimal(10, 2)
  rate         Decimal          @db.Decimal(5, 4)
  status       CommissionStatus @default(PENDING)
  payoutId     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  order      Order      @relation(fields: [orderId], references: [id])
  ambassador Ambassador @relation(fields: [ambassadorId], references: [id])
  payout     Payout?    @relation(fields: [payoutId], references: [id])
}

model Payout {
  id           String       @id @default(cuid())
  ambassadorId String
  amount       Decimal      @db.Decimal(10, 2)
  method       String       @default("bank_transfer")
  reference    String?
  status       PayoutStatus @default(PENDING)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  ambassador  Ambassador   @relation(fields: [ambassadorId], references: [id])
  commissions Commission[]
}

// ─── Inventory & Operations ───────────────────────────────────────────────────

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum StockMovementType {
  PURCHASE           // Stock received from supplier / purchase
  PRODUCTION_USE     // Consumed in a production run
  PRODUCTION_OUTPUT  // Finished goods added after packaging
  ORDER_FULFILLMENT  // Stock deducted when order confirmed
  ADJUSTMENT_IN      // Manual upward correction
  ADJUSTMENT_OUT     // Manual downward correction / write-off
  WASTE              // Spoilage or expiry
  RETURN             // Returned to supplier
}

enum PackagingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model Supplier {
  id          String         @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  city        String?
  notes       String?
  status      SupplierStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]
  quoteRequests  SupplierQuoteRequest[]
  supplierQuotes SupplierQuote[]
}

model StockItem {
  id            String   @id @default(cuid())
  productId     String   @unique          // Every stock item must be backed by a Product
  name          String
  sku           String?  @unique
  unit          String?  // legacy fallback — prefer uomId
  uomId         String?  // FK → UnitOfMeasure
  currentStock  Decimal  @default(0) @db.Decimal(12, 3)
  minStockLevel Decimal  @default(0) @db.Decimal(12, 3)
  costPerUnit   Decimal  @default(0) @db.Decimal(10, 4)
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product            Product            @relation(fields: [productId], references: [id])
  uom                UnitOfMeasure?     @relation(fields: [uomId], references: [id])
  movements          StockMovement[]
  recipeIngredients  RecipeIngredient[]
  purchaseOrderItems PurchaseOrderItem[]
  packagingRunItems  PackagingRunItem[]
  supplierQuotes     SupplierQuote[]
  marketPrices       MarketPrice[]
  quoteRequestItems  SupplierQuoteRequestItem[]
}

model StockMovement {
  id              String            @id @default(cuid())
  stockItemId     String
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3) // positive=in, negative=out
  unitCost        Decimal?          @db.Decimal(10, 4)
  reference       String?           // PO id, production run id, etc.
  note            String?
  productionRunId String?
  purchaseOrderId String?
  createdAt       DateTime          @default(now())

  stockItem     StockItem      @relation(fields: [stockItemId], references: [id])
  productionRun ProductionRun? @relation(fields: [productionRunId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
}

model Recipe {
  id              String   @id @default(cuid())
  name            String
  productId       String?
  outputProductId String?  // FK → Product (the finished good this recipe produces)
  yieldQty        Decimal  @default(1) @db.Decimal(10, 3) // units this recipe produces
  yieldUnit       String   @default("batch")
  yieldPerBatch   Decimal  @default(0) @db.Decimal(10, 3) // sellable units produced per batch
  notes           String?
  instructions    String?  // preparation method / steps
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  outputProduct  Product?          @relation("RecipeOutput", fields: [outputProductId], references: [id])
  ingredients    RecipeIngredient[]
  productionRuns ProductionRun[]
}

model RecipeIngredient {
  id          String  @id @default(cuid())
  recipeId    String
  stockItemId String
  quantity    Decimal @db.Decimal(12, 3)
  unit        String? // legacy fallback
  uomId       String? // FK → UnitOfMeasure
  notes       String?

  recipe    Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stockItem StockItem      @relation(fields: [stockItemId], references: [id])
  uom       UnitOfMeasure? @relation(fields: [uomId], references: [id])
}

model ProductionRun {
  id          String           @id @default(cuid())
  recipeId    String
  batches     Decimal          @default(1) @db.Decimal(10, 3)
  status      ProductionStatus @default(PLANNED)
  plannedDate DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  recipe         Recipe          @relation(fields: [recipeId], references: [id])
  stockMovements StockMovement[]
  packagingRun   PackagingRun?
}

model PackagingRun {
  id              String          @id @default(cuid())
  productionRunId String          @unique
  productionRun   ProductionRun   @relation(fields: [productionRunId], references: [id])
  status          PackagingStatus @default(PENDING)
  batchCount      Int             @default(1)
  notes           String?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items PackagingRunItem[]
}

model PackagingRunItem {
  id             String       @id @default(cuid())
  packagingRunId String
  packagingRun   PackagingRun @relation(fields: [packagingRunId], references: [id])
  stockItemId    String
  stockItem      StockItem    @relation(fields: [stockItemId], references: [id])
  quantity       Decimal      @db.Decimal(10, 3)
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  notes        String?
  total        Decimal             @default(0) @db.Decimal(10, 2)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  items          PurchaseOrderItem[]
  stockMovements StockMovement[]
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  stockItemId     String
  orderedQty      Decimal @db.Decimal(12, 3)
  receivedQty     Decimal @default(0) @db.Decimal(12, 3)
  unitCost        Decimal @db.Decimal(10, 4)
  total           Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem     StockItem     @relation(fields: [stockItemId], references: [id])
}

// ─── Finance ──────────────────────────────────────────────────────────────────

enum AccountType {
  ASSET       // Cash, bank accounts, receivables
  LIABILITY   // Loans, payables
  EQUITY      // Owner's equity, retained earnings
  INCOME      // Revenue streams
  EXPENSE     // Operating costs
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BankTransactionStatus {
  UNMATCHED
  MATCHED
  IGNORED
}

model FinanceAccount {
  id          String      @id @default(cuid())
  code        String      @unique   // e.g. "4001"
  name        String                // e.g. "Product Sales"
  type        AccountType
  description String?
  isActive    Boolean     @default(true)
  isSystem    Boolean     @default(false) // system accounts cannot be deleted
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  transactions FinanceTransaction[]
}

model FinanceTransaction {
  id            String          @id @default(cuid())
  date          DateTime        @default(now())
  amount        Decimal         @db.Decimal(10, 2)
  type          TransactionType
  category      String          // mirrors account name; free-text fallback if no accountId
  accountId     String?         // FK to FinanceAccount (optional)
  description   String
  reference     String?
  attachmentUrl String?
  orderId       String?         @unique // auto-linked when a sale is recorded
  bankTxnId     String?         @unique // linked when matched to a bank transaction
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  account FinanceAccount?  @relation(fields: [accountId], references: [id])
  order   Order?           @relation(fields: [orderId], references: [id])
  bankTxn BankTransaction? @relation(fields: [bankTxnId], references: [id])
}

model BankAccount {
  id            String   @id @default(cuid())
  name          String   // e.g. "FNB Business Cheque"
  bankName      String?
  accountNumber String?
  balance       Decimal  @default(0) @db.Decimal(10, 2)
  currency      String   @default("ZAR")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions BankTransaction[]
}

model BankTransaction {
  id            String                @id @default(cuid())
  bankAccountId String
  date          DateTime
  description   String
  amount        Decimal               @db.Decimal(10, 2) // positive=credit, negative=debit
  balance       Decimal?              @db.Decimal(10, 2)
  reference     String?
  status        BankTransactionStatus @default(UNMATCHED)
  createdAt     DateTime              @default(now())

  bankAccount BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  transaction FinanceTransaction? // reverse relation via bankTxnId on FinanceTransaction
}

// ─── Quotes ───────────────────────────────────────────────────────────────────

model Quote {
  id             String      @id @default(cuid())
  number         String      @unique
  customerId     String
  ambassadorId   String?
  createdById    String
  status         QuoteStatus @default(DRAFT)
  subtotal       Decimal     @db.Decimal(10, 2)
  deliveryFee    Decimal     @default(0) @db.Decimal(10, 2)
  discountType   String?     // 'PERCENTAGE' | 'FLAT'
  discountValue  Decimal?    @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  notes          String?
  validUntil     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customer   User        @relation("QuoteCustomer",  fields: [customerId],  references: [id])
  createdBy  User        @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  ambassador Ambassador? @relation(fields: [ambassadorId], references: [id])
  items      QuoteItem[]
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)

  quote   Quote          @relation(fields: [quoteId],   references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

// ─── Discount Rules ───────────────────────────────────────────────────────────

model DiscountRule {
  id          String   @id @default(cuid())
  name        String
  code        String?  @unique
  type        String   // 'PERCENTAGE' | 'FLAT'
  value       Decimal  @db.Decimal(10, 2)
  minOrder    Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Company & Departments ────────────────────────────────────────────────────

model Company {
  id             String   @id @default(cuid())
  name           String   @default("Tlaka Treats")
  tradingName    String?
  registrationNo String?
  vatNo          String?
  address        String?
  city           String?
  province       String?
  postalCode     String?
  phone          String?
  email          String?
  website        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  managerId   String?
  manager     Employee?  @relation("DeptManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees   Employee[] @relation("EmpDepartment")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ─── Employees ────────────────────────────────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CASUAL
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum ShiftAssignmentStatus {
  SCHEDULED
  COMPLETED
  ABSENT
  LATE
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  FAMILY
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum QualificationType {
  QUALIFICATION
  CERTIFICATION
  LICENCE
  TRAINING
  OTHER
}

enum QualificationStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  REVOKED
}

enum ContractType {
  PERMANENT
  FIXED_TERM
  CASUAL
  INDEPENDENT_CONTRACTOR
}

enum ContractStatus {
  ACTIVE
  PENDING
  EXPIRED
  TERMINATED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Employee {
  id             String         @id @default(cuid())
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id])
  employeeCode   String         @unique
  jobTitle       String
  department     String?
  departmentId   String?
  departmentRel  Department?    @relation("EmpDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  reportsToId    String?
  reportsTo      Employee?      @relation("ReportingLine", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports  Employee[]     @relation("ReportingLine")
  managedDepts   Department[]   @relation("DeptManager")
  employmentType EmploymentType @default(FULL_TIME)
  startDate      DateTime       @db.Date
  endDate        DateTime?      @db.Date
  hourlyRate     Decimal?       @db.Decimal(10, 2)
  monthlyRate    Decimal?       @db.Decimal(10, 2)
  bio            String?
  bankName       String?
  bankAccount    String?
  bankBranch     String?
  notes          String?
  status         EmployeeStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  shifts         ShiftAssignment[]
  leaveRequests  LeaveRequest[]
  payrollItems   PayrollItem[]
  qualifications EmployeeQualification[]
  contracts      EmployeeContract[]
  timesheets     Timesheet[]
  tasks          Task[]
}

model EmployeeQualification {
  id          String              @id @default(cuid())
  employeeId  String
  employee    Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        QualificationType
  name        String
  issuedBy    String?
  issueDate   DateTime?           @db.Date
  expiryDate  DateTime?           @db.Date
  documentUrl String?
  status      QualificationStatus @default(VALID)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model EmployeeContract {
  id           String         @id @default(cuid())
  employeeId   String
  employee     Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  contractType ContractType
  title        String
  startDate    DateTime       @db.Date
  endDate      DateTime?      @db.Date
  grossSalary  Decimal?       @db.Decimal(10, 2)
  hourlyRate   Decimal?       @db.Decimal(10, 2)
  hoursPerWeek Int?
  status       ContractStatus @default(ACTIVE)
  documentUrl  String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Timesheet {
  id          String          @id @default(cuid())
  employeeId  String
  employee    Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  weekStart   DateTime        @db.Date
  weekEnd     DateTime        @db.Date
  totalHours  Decimal         @default(0) @db.Decimal(5, 2)
  status      TimesheetStatus @default(DRAFT)
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  entries TimesheetEntry[]

  @@unique([employeeId, weekStart])
}

model TimesheetEntry {
  id                String    @id @default(cuid())
  timesheetId       String
  timesheet         Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  date              DateTime  @db.Date
  hoursWorked       Decimal   @db.Decimal(5, 2)
  startTime         String?
  endTime           String?
  breakMins         Int       @default(0)
  shiftAssignmentId String?
  description       String?
  createdAt         DateTime  @default(now())

  @@unique([timesheetId, date])
}

model Shift {
  id          String   @id @default(cuid())
  name        String
  startTime   String   // "06:00"
  endTime     String   // "14:00"
  breakMins   Int      @default(30)
  createdAt   DateTime @default(now())

  assignments ShiftAssignment[]
}

model ShiftAssignment {
  id          String                @id @default(cuid())
  employeeId  String
  employee    Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftId     String
  shift       Shift                 @relation(fields: [shiftId], references: [id])
  date        DateTime              @db.Date
  status      ShiftAssignmentStatus @default(SCHEDULED)
  clockIn     DateTime?
  clockOut    DateTime?
  hoursWorked Decimal?              @db.Decimal(5, 2)
  notes       String?
  createdAt   DateTime              @default(now())

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       LeaveType
  fromDate   DateTime    @db.Date
  toDate     DateTime    @db.Date
  days       Int
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model PayrollRun {
  id                   String        @id @default(cuid())
  period               String        // "2026-03"
  status               PayrollStatus @default(DRAFT)
  totalGross           Decimal       @db.Decimal(10, 2)
  totalNet             Decimal       @db.Decimal(10, 2)
  processedAt          DateTime?
  financeTransactionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  items PayrollItem[]
}

model PayrollItem {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id])
  hoursWorked  Decimal    @db.Decimal(5, 2)
  grossPay     Decimal    @db.Decimal(10, 2)
  deductions   Decimal    @default(0) @db.Decimal(10, 2)
  netPay       Decimal    @db.Decimal(10, 2)
  notes        String?
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskSource {
  MANUAL
  BOARD_MEETING
  STRATEGY
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(OPEN)
  dueDate     DateTime?    @db.Date
  owner       String?
  employeeId  String?
  employee    Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  strategyId  String?
  strategy    Strategy?    @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  source      TaskSource   @default(MANUAL)
  sourceId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── AI Strategy ──────────────────────────────────────────────────────────────

enum StrategyStatus {
  GENERATING
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  ARCHIVED
}

model Strategy {
  id             String         @id @default(cuid())
  title          String         @default("Business Strategy")
  status         StrategyStatus @default(GENERATING)
  errorMessage   String?
  contextJson    Json           @default("{}")
  snapshotJson   Json           @default("{}")
  contentJson    Json           @default("{}")
  currentVersion Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  progressJson   Json              @default("{}")
  revisions      StrategyRevision[]
  comments       StrategyComment[]
  tasks          Task[]
}

model StrategyRevision {
  id          String   @id @default(cuid())
  strategyId  String
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  version     Int
  contentJson Json
  changeType  String   // AI_GENERATED | AI_REFINED | MANUAL_EDIT
  changeNote  String?
  createdAt   DateTime @default(now())
}

model StrategyComment {
  id         String   @id @default(cuid())
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  section    String?
  body       String
  author     String?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─── Bohlale Chat ─────────────────────────────────────────────────────────────

model ChatConversation {
  id        String        @id @default(cuid())
  title     String        @default("New Chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String           // 'user' | 'assistant'
  content        String
  createdAt      DateTime         @default(now())
}

model KnowledgeDocument {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String
  fileType    String   @default("text")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── AI Advisory Board ────────────────────────────────────────────────────────

model BoardMeeting {
  id            String   @id @default(cuid())
  periodDays    Int      @default(30)
  debateEnabled Boolean  @default(false)
  status        String   @default("RUNNING")   // RUNNING | COMPLETED | FAILED
  errorMessage  String?
  snapshotJson  Json     @default("{}")
  reportJson    Json     @default("{}")
  createdAt     DateTime @default(now())
}

// ─── Pricing Agent ────────────────────────────────────────────────────────────

model SupplierQuoteRequest {
  id         String    @id @default(cuid())
  supplierId String
  supplier   Supplier  @relation(fields: [supplierId], references: [id])
  subject    String
  body       String
  status     String    @default("SENT")  // SENT | RESPONDED | CLOSED
  sentAt     DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items  SupplierQuoteRequestItem[]
  quotes SupplierQuote[]
}

model SupplierQuoteRequestItem {
  id          String               @id @default(cuid())
  requestId   String
  request     SupplierQuoteRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem            @relation(fields: [stockItemId], references: [id])
}

model SupplierQuote {
  id           String                @id @default(cuid())
  supplierId   String
  supplier     Supplier              @relation(fields: [supplierId], references: [id])
  requestId    String?
  request      SupplierQuoteRequest? @relation(fields: [requestId], references: [id])
  stockItemId  String
  stockItem    StockItem             @relation(fields: [stockItemId], references: [id])
  pricePerUnit Decimal               @db.Decimal(10, 4)
  packSize     Decimal?              @db.Decimal(10, 3)
  packPrice    Decimal?              @db.Decimal(10, 2)
  unitLabel    String?
  validUntil   DateTime?
  source       String                @default("manual")
  notes        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model MarketPrice {
  id           String     @id @default(cuid())
  stockItemId  String?
  stockItem    StockItem? @relation(fields: [stockItemId], references: [id])
  searchTerm   String?
  pricePerUnit Decimal    @db.Decimal(10, 4)
  unitLabel    String?
  source       String
  url          String?
  rawSnippet   String?
  checkedAt    DateTime   @default(now())
  createdAt    DateTime   @default(now())
}

model PricingStore {
  id        String   @id @default(cuid())
  name      String
  domain    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id          String    @id @default(cuid())
  name        String?
  contact     String?
  sourceName  String?
  sourceUrl   String?
  leadType    String    @default("GENERAL")   // EVENT | DIRECT | WHOLESALE | GENERAL
  eventType   String?                          // WEDDING | FUNERAL | CORPORATE | BIRTHDAY | OTHER
  eventDate   DateTime?
  location    String?
  description String?
  status      String    @default("NEW")       // NEW | CONTACTED | INTERESTED | CONVERTED | DEAD
  notes       String?
  outreach    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
