DATABASE_URL="postgresql://postgres:password@localhost:5432/tlaka_treats"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
PORT=3000
NODE_ENV=development

# Public URL of this API (used for PDF links in WhatsApp messages)
APP_URL=https://your-api-url.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────
# Works with Gmail App Password, SendGrid, Mailgun SMTP, etc.
# For Gmail: enable 2FA → create App Password → use that as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Tlaka Treats <hello@tlakatreats.co.za>"
# Admin email for internal alerts (low stock). Defaults to SMTP_USER if not set.
ADMIN_EMAIL=admin@tlakatreats.co.za

# ── AI Advisory Board ─────────────────────────────────────────────────────
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp via Twilio ───────────────────────────────────────────────────
# Sign up at twilio.com → enable WhatsApp sandbox → get credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox number (default below) or your approved WhatsApp Business number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
