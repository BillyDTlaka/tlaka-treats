{
  "name": "tlaka-treats-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema src/prisma/schema.prisma",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema src/prisma/schema.prisma",
    "db:generate": "prisma generate --schema src/prisma/schema.prisma",
    "db:seed": "tsx src/prisma/seed.ts",
    "db:reset-and-seed": "prisma migrate deploy --schema src/prisma/schema.prisma && tsx src/prisma/seed.ts",
    "db:studio": "prisma studio --schema src/prisma/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^9.1.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "prisma": "^5.14.0",
    "twilio": "^5.12.2",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx src/prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  }
}
