{
  "expo": {
    "name": "Tlaka Treats Admin",
    "slug": "tlaka-treats-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ttadmin",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#8B3A3A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.za.tlakatreats.admin"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#8B3A3A"
      },
      "package": "co.za.tlakatreats.admin"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
